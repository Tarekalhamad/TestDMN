  <dmn:decision id="_DECISION_RESULT" name="CompatibilityResult">
    <dmn:extensionElements />
    <dmn:variable id="_VAR_RESULT" name="CompatibilityResult" typeRef="Any" />
    <dmn:informationRequirement id="_IR_ELIGIBLE">
      <dmn:requiredInput href="#_INPUT_ELIGIBLE" />
    </dmn:informationRequirement>
    <dmn:informationRequirement id="_IR_PRECEDENCE">
      <dmn:requiredDecision href="#_DECISION_PRECEDENCE" />
    </dmn:informationRequirement>
    <dmn:informationRequirement id="_IR_CAT_RULES">
      <dmn:requiredDecision href="#_DECISION_CAT_RULES" />
    </dmn:informationRequirement>
    <dmn:informationRequirement id="_IR_PROMO_RULES">
      <dmn:requiredDecision href="#_DECISION_PROMO_RULES" />
    </dmn:informationRequirement>
    <dmn:informationRequirement id="_IR_ALLOWED_RULES">
      <dmn:requiredDecision href="#_DECISION_ALLOWED_RULES" />
    </dmn:informationRequirement>
    <dmn:context id="_CTX_RESULT">
      <dmn:contextEntry>
        <dmn:variable id="_CE_PREC" name="categoryPrecedence" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_PREC">
          <dmn:text>CategoryPrecedence</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_CAT_RULES" name="categoryBlockingRules" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_CAT_RULES">
          <dmn:text>CategoryBlockingRules</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_PROMO_RULES" name="promotionBlockingRules" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_PROMO_RULES">
          <dmn:text>PromotionBlockingRules</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_ALLOWED_RULES" name="promotionExceptionRules" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_ALLOWED_RULES">
          <dmn:text>PromotionExceptionRules</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_PREC_OF" name="precedenceOf" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_PREC_OF">
          <dmn:text>function(cat) if count(categoryPrecedence[discountCategory = cat]) &gt; 0 then (categoryPrecedence[discountCategory = cat]).precedenceRank[1] else 999</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_CATS" name="categoriesPresent" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_CATS">
          <dmn:text>distinct values(for p in EligiblePromotions return p.discountCategory)</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_CONFLICTS" name="activeConflicts" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_CONFLICTS">
          <dmn:text>categoryBlockingRules[list contains(categoriesPresent, groupA) and list contains(categoriesPresent, groupB)]</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_RESOLUTIONS" name="conflictResolutions" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_RESOLUTIONS">
          <dmn:text>for c in activeConflicts return {winnerCategory: if c.overrideWinner != null then c.overrideWinner else if precedenceOf(c.groupA) &lt; precedenceOf(c.groupB) then c.groupA else c.groupB, loserCategory: if c.overrideWinner != null then (if c.overrideWinner = c.groupA then c.groupB else c.groupA) else if precedenceOf(c.groupA) &lt; precedenceOf(c.groupB) then c.groupB else c.groupA, isOverride: c.overrideWinner != null}</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_LOSERS" name="losingCategories" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_LOSERS">
          <dmn:text>distinct values(for cr in conflictResolutions return cr.loserCategory)</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_CAT_EXEMPTED" name="categoryExemptedIds" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_CAT_EXEMPTED">
          <dmn:text>distinct values((for p in EligiblePromotions[list contains(losingCategories, discountCategory)] return if (some rule in promotionExceptionRules satisfies rule.promotion = p.promotionId and (rule.allowedWithGroup = conflictResolutions[loserCategory = p.discountCategory][1].winnerCategory or (rule.allowedWithPromotion != null and (some winner in EligiblePromotions[discountCategory = conflictResolutions[loserCategory = p.discountCategory][1].winnerCategory] satisfies winner.promotionId = rule.allowedWithPromotion)))) then p.promotionId else null)[item != null])</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_ACTIVE_BLOCKS" name="activeBlocks" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_ACTIVE_BLOCKS">
          <dmn:text>(for rule in promotionBlockingRules return if (rule.blockedByGroup != null and list contains(categoriesPresent, rule.blockedByGroup)) or (rule.blockedByPromotion != null and (some p in EligiblePromotions satisfies p.promotionId = rule.blockedByPromotion)) then rule else null)[item != null]</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_BLOCKED_IDS" name="blockedPromotionIds" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_BLOCKED_IDS">
          <dmn:text>distinct values(for b in activeBlocks return if b.overrideWinner = null or b.overrideWinner = "" then b.promotion else if b.overrideWinner = "BY_PRECEDENCE" then (if b.blockedByPromotion != null and (some p in EligiblePromotions satisfies p.promotionId = b.blockedByPromotion) then (if precedenceOf((EligiblePromotions[promotionId = b.promotion])[1].discountCategory) &lt; precedenceOf((EligiblePromotions[promotionId = b.blockedByPromotion])[1].discountCategory) then b.blockedByPromotion else b.promotion) else b.promotion) else if b.overrideWinner = b.promotion then b.blockedByPromotion else b.promotion)</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_PROMO_EXEMPTED" name="promoExemptedIds" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_PROMO_EXEMPTED">
          <dmn:text>distinct values((for pid in blockedPromotionIds return if (some rule in promotionExceptionRules satisfies rule.promotion = pid and ((rule.allowedWithGroup != null and list contains(categoriesPresent, rule.allowedWithGroup)) or (rule.allowedWithPromotion != null and (some p in EligiblePromotions satisfies p.promotionId = rule.allowedWithPromotion)))) then pid else null)[item != null])</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_SURVIVING" name="surviving" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_SURVIVING">
          <dmn:text>EligiblePromotions[(not(list contains(losingCategories, discountCategory)) or list contains(categoryExemptedIds, promotionId)) and (not(list contains(blockedPromotionIds, promotionId)) or list contains(promoExemptedIds, promotionId))]</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_SORTED" name="sorted" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_SORTED">
          <dmn:text>sort(surviving, function(a, b) precedenceOf(a.discountCategory) &lt; precedenceOf(b.discountCategory))</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_ALLOWED" name="allowedResult" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_ALLOWED">
          <dmn:text>if count(sorted) = 0 then [] else for i in 1..count(sorted) return {promotionId: sorted[i].promotionId, promotionName: sorted[i].promotionName, discountCategory: sorted[i].discountCategory, appliedOrder: i}</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_CAT_REJECTED" name="categoryRejections" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_CAT_REJECTED">
          <dmn:text>for p in EligiblePromotions[list contains(losingCategories, discountCategory) and not(list contains(categoryExemptedIds, promotionId))] return {promotionId: p.promotionId, promotionName: p.promotionName, discountCategory: p.discountCategory, reason: "Incompatible with " + conflictResolutions[loserCategory = p.discountCategory][1].winnerCategory + (if conflictResolutions[loserCategory = p.discountCategory][1].isOverride then " (override winner)" else " (higher precedence)")}</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_BUILD_REASON" name="buildReason" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_BUILD_REASON">
          <dmn:text>function(rule) if rule = null then "Blocked by promotion rule" else (if rule.blockedByGroup != null and rule.blockedByPromotion != null then "Blocked by category " + rule.blockedByGroup + " or promotion " + (if count(EligiblePromotions[promotionId = rule.blockedByPromotion]) &gt; 0 then EligiblePromotions[promotionId = rule.blockedByPromotion][1].promotionName + " (" + rule.blockedByPromotion + ")" else rule.blockedByPromotion) else if rule.blockedByGroup != null then "Blocked by category " + rule.blockedByGroup else "Blocked by promotion " + (if count(EligiblePromotions[promotionId = rule.blockedByPromotion]) &gt; 0 then EligiblePromotions[promotionId = rule.blockedByPromotion][1].promotionName + " (" + rule.blockedByPromotion + ")" else rule.blockedByPromotion)) + (if rule.overrideWinner != null and rule.overrideWinner != "" then (if rule.overrideWinner = "BY_PRECEDENCE" then ", winner by precedence" else ", winner: " + (if count(EligiblePromotions[promotionId = rule.overrideWinner]) &gt; 0 then EligiblePromotions[promotionId = rule.overrideWinner][1].promotionName + " (" + rule.overrideWinner + ")" else rule.overrideWinner)) else "")</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_PROMO_REJECTED" name="promotionRejections" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_PROMO_REJECTED">
          <dmn:text>for p in EligiblePromotions[list contains(blockedPromotionIds, promotionId) and not(list contains(promoExemptedIds, promotionId)) and not(list contains(losingCategories, discountCategory))] return {promotionId: p.promotionId, promotionName: p.promotionName, discountCategory: p.discountCategory, reason: buildReason(if count(activeBlocks[promotion = p.promotionId]) &gt; 0 then activeBlocks[promotion = p.promotionId][1] else if count(activeBlocks[blockedByPromotion = p.promotionId]) &gt; 0 then activeBlocks[blockedByPromotion = p.promotionId][1] else null)}</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_REJECTED" name="rejectedResult" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_REJECTED">
          <dmn:text>concatenate(categoryRejections, promotionRejections)</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:literalExpression id="_EXPR_FINAL">
          <dmn:text>{AllowedPromotions: allowedResult, RejectedPromotions: rejectedResult}</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
    </dmn:context>
  </dmn:decision>
  <dmn:decision id="_DECISION_ALLOWED_RULES" name="PromotionExceptionRules">
    <dmn:extensionElements />
    <dmn:variable id="_VAR_ALLOWED_RULES" name="PromotionExceptionRules" typeRef="tAllowedRuleList" />
    <dmn:decisionTable id="_DT_ALLOWED_RULES" hitPolicy="COLLECT" preferredOrientation="Rule-as-Row" outputLabel="PromotionExceptionRules">
      <dmn:input id="_DT_AR_IN1">
        <dmn:inputExpression id="_DT_AR_IE1" typeRef="string">
          <dmn:text>"match"</dmn:text>
        </dmn:inputExpression>
      </dmn:input>
      <dmn:output id="_DT_AR_OUT1" name="promotion" typeRef="string" />
      <dmn:output id="_DT_AR_OUT2" name="allowedWithGroup" typeRef="string" />
      <dmn:output id="_DT_AR_OUT3" name="allowedWithPromotion" typeRef="string" />
      <dmn:annotation name="" />
      <dmn:rule id="_DT_AR_R1">
        <dmn:inputEntry id="_DT_AR_R1_I1">
          <dmn:text>-</dmn:text>
        </dmn:inputEntry>
        <dmn:outputEntry id="_DT_AR_R1_O1">
          <dmn:text>"5"</dmn:text>
        </dmn:outputEntry>
        <dmn:outputEntry id="_DT_AR_R1_O2">
          <dmn:text>"EmployeeDiscount"</dmn:text>
        </dmn:outputEntry>
        <dmn:outputEntry id="_DT_AR_R1_O3">
          <dmn:text></dmn:text>
        </dmn:outputEntry>
        <dmn:annotationEntry>
          <dmn:text>Test: Kombo discount is aexempted from Employee category conflict</dmn:text>
        </dmn:annotationEntry>
      </dmn:rule>
      <dmn:rule id="_DT_AR_R2">
        <dmn:inputEntry id="_DT_AR_R2_I1">
          <dmn:text>-</dmn:text>
        </dmn:inputEntry>
        <dmn:outputEntry id="_DT_AR_R2_O1">
          <dmn:text>"EX002"</dmn:text>
        </dmn:outputEntry>
        <dmn:outputEntry id="_DT_AR_R2_O2">
          <dmn:text></dmn:text>
        </dmn:outputEntry>
        <dmn:outputEntry id="_DT_AR_R2_O3">
          <dmn:text>"449"</dmn:text>
        </dmn:outputEntry>
        <dmn:annotationEntry>
          <dmn:text>Test: Promo exempted from specific promotion block</dmn:text>
        </dmn:annotationEntry>
      </dmn:rule>
      <dmn:rule id="DecisionRule_0xnifav">
        <dmn:inputEntry id="UnaryTests_02zak9y">
          <dmn:text></dmn:text>
        </dmn:inputEntry>
        <dmn:outputEntry id="LiteralExpression_13ui8v2">
          <dmn:text>"500"</dmn:text>
        </dmn:outputEntry>
        <dmn:outputEntry id="LiteralExpression_01moits">
          <dmn:text>"EmployeeDiscount"</dmn:text>
        </dmn:outputEntry>
        <dmn:outputEntry id="LiteralExpression_1mm6vml">
          <dmn:text></dmn:text>
        </dmn:outputEntry>
      </dmn:rule>
    </dmn:decisionTable>
  </dmn:decision>
  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="_DIAGRAM_001" name="DRG">
      <di:extension>
        <kie:ComponentsWidthsExtension>
          <kie:ComponentWidths dmnElementRef="_DT_PRECEDENCE" />
          <kie:ComponentWidths dmnElementRef="_DT_CAT_RULES" />
          <kie:ComponentWidths dmnElementRef="_DT_PROMO_RULES" />
          <kie:ComponentWidths dmnElementRef="_CTX_RESULT" />
          <kie:ComponentWidths dmnElementRef="_EXPR_PREC" />
          <kie:ComponentWidths dmnElementRef="_EXPR_CAT_RULES" />
          <kie:ComponentWidths dmnElementRef="_EXPR_PROMO_RULES" />
          <kie:ComponentWidths dmnElementRef="_EXPR_ALLOWED_RULES" />
          <kie:ComponentWidths dmnElementRef="_EXPR_PREC_OF" />
