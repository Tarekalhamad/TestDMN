  <dmn:decision id="_DECISION_RESULT" name="CompatibilityResult">
    <dmn:extensionElements />
    <dmn:variable id="_VAR_RESULT" name="CompatibilityResult" typeRef="Any" />
    <dmn:informationRequirement id="_IR_ELIGIBLE">
      <dmn:requiredInput href="#_INPUT_ELIGIBLE" />
    </dmn:informationRequirement>
    <dmn:informationRequirement id="_IR_PRECEDENCE">
      <dmn:requiredDecision href="#_DECISION_PRECEDENCE" />
    </dmn:informationRequirement>
    <dmn:informationRequirement id="_IR_CAT_RULES">
      <dmn:requiredDecision href="#_DECISION_CAT_RULES" />
    </dmn:informationRequirement>
    <dmn:informationRequirement id="_IR_PROMO_RULES">
      <dmn:requiredDecision href="#_DECISION_PROMO_RULES" />
    </dmn:informationRequirement>
    <dmn:context id="_CTX_RESULT">
      <dmn:contextEntry>
        <dmn:variable id="_CE_PREC" name="categoryPrecedence" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_PREC">
          <dmn:text>CategoryPrecedence</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_CAT_RULES" name="categoryRules" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_CAT_RULES">
          <dmn:text>CategoryRules</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_PROMO_RULES" name="promotionRules" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_PROMO_RULES">
          <dmn:text>PromotionRules</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_PREC_OF" name="precedenceOf" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_PREC_OF">
          <dmn:text>function(cat) if count(categoryPrecedence[discountCategory = cat]) &gt; 0 then (categoryPrecedence[discountCategory = cat]).precedenceRank[1] else 999</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_CATS" name="categoriesPresent" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_CATS">
          <dmn:text>distinct values(for p in EligiblePromotions return p.discountCategory)</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_CONFLICTS" name="activeConflicts" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_CONFLICTS">
          <dmn:text>categoryRules[list contains(categoriesPresent, groupA) and list contains(categoriesPresent, groupB)]</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_RESOLUTIONS" name="conflictResolutions" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_RESOLUTIONS">
          <dmn:text>for c in activeConflicts return {winnerCategory: if c.overrideWinner != null then c.overrideWinner else if precedenceOf(c.groupA) &lt; precedenceOf(c.groupB) then c.groupA else c.groupB, loserCategory: if c.overrideWinner != null then (if c.overrideWinner = c.groupA then c.groupB else c.groupA) else if precedenceOf(c.groupA) &lt; precedenceOf(c.groupB) then c.groupB else c.groupA, isOverride: c.overrideWinner != null}</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_LOSERS" name="losingCategories" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_LOSERS">
          <dmn:text>distinct values(for cr in conflictResolutions return cr.loserCategory)</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_ACTIVE_BLOCKS" name="activeBlocks" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_ACTIVE_BLOCKS">
          <dmn:text>(for rule in promotionRules return if (rule.blockedByGroup != null and list contains(categoriesPresent, rule.blockedByGroup)) or (rule.blockedByPromotion != null and (some p in EligiblePromotions satisfies p.promotionId = rule.blockedByPromotion)) then rule else null)[item != null]</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_BLOCKED_IDS" name="blockedPromotionIds" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_BLOCKED_IDS">
          <dmn:text>distinct values(for b in activeBlocks return if b.overrideWinner = null or b.overrideWinner = "" then b.promotion else if b.overrideWinner = "BY_PRECEDENCE" then (if b.blockedByPromotion != null and (some p in EligiblePromotions satisfies p.promotionId = b.blockedByPromotion) then (if precedenceOf((EligiblePromotions[promotionId = b.promotion])[1].discountCategory) &lt; precedenceOf((EligiblePromotions[promotionId = b.blockedByPromotion])[1].discountCategory) then b.blockedByPromotion else b.promotion) else b.promotion) else if b.overrideWinner = b.promotion then b.blockedByPromotion else b.promotion)</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_SURVIVING" name="surviving" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_SURVIVING">
          <dmn:text>EligiblePromotions[not(list contains(losingCategories, discountCategory)) and not(list contains(blockedPromotionIds, promotionId))]</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_SORTED" name="sorted" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_SORTED">
          <dmn:text>sort(surviving, function(a, b) precedenceOf(a.discountCategory) &lt; precedenceOf(b.discountCategory))</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_ALLOWED" name="allowedResult" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_ALLOWED">
          <dmn:text>if count(sorted) = 0 then [] else for i in 1..count(sorted) return {promotionId: sorted[i].promotionId, promotionName: sorted[i].promotionName, discountCategory: sorted[i].discountCategory, appliedOrder: i}</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_CAT_REJECTED" name="categoryRejections" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_CAT_REJECTED">
          <dmn:text>for p in EligiblePromotions[list contains(losingCategories, discountCategory)] return {promotionId: p.promotionId, promotionName: p.promotionName, discountCategory: p.discountCategory, reason: "Incompatible with " + conflictResolutions[loserCategory = p.discountCategory][1].winnerCategory + (if conflictResolutions[loserCategory = p.discountCategory][1].isOverride then " (override winner)" else " (higher precedence)")}</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_BUILD_REASON" name="buildReason" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_BUILD_REASON">
          <dmn:text>function(rule) if rule = null then "Blocked by promotion rule" else (if rule.blockedByGroup != null and rule.blockedByPromotion != null then "Blocked by category " + rule.blockedByGroup + " or promotion " + (if count(EligiblePromotions[promotionId = rule.blockedByPromotion]) &gt; 0 then EligiblePromotions[promotionId = rule.blockedByPromotion][1].promotionName + " (" + rule.blockedByPromotion + ")" else rule.blockedByPromotion) else if rule.blockedByGroup != null then "Blocked by category " + rule.blockedByGroup else "Blocked by promotion " + (if count(EligiblePromotions[promotionId = rule.blockedByPromotion]) &gt; 0 then EligiblePromotions[promotionId = rule.blockedByPromotion][1].promotionName + " (" + rule.blockedByPromotion + ")" else rule.blockedByPromotion)) + (if rule.overrideWinner != null and rule.overrideWinner != "" then (if rule.overrideWinner = "BY_PRECEDENCE" then ", winner by precedence" else ", winner: " + (if count(EligiblePromotions[promotionId = rule.overrideWinner]) &gt; 0 then EligiblePromotions[promotionId = rule.overrideWinner][1].promotionName + " (" + rule.overrideWinner + ")" else rule.overrideWinner)) else "")</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_PROMO_REJECTED" name="promotionRejections" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_PROMO_REJECTED">
          <dmn:text>for p in EligiblePromotions[list contains(blockedPromotionIds, promotionId) and not(list contains(losingCategories, discountCategory))] return {promotionId: p.promotionId, promotionName: p.promotionName, discountCategory: p.discountCategory, reason: buildReason(if count(activeBlocks[promotion = p.promotionId]) &gt; 0 then activeBlocks[promotion = p.promotionId][1] else if count(activeBlocks[blockedByPromotion = p.promotionId]) &gt; 0 then activeBlocks[blockedByPromotion = p.promotionId][1] else null)}</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_REJECTED" name="rejectedResult" typeRef="Any" />
        <dmn:literalExpression id="_EXPR_REJECTED">
          <dmn:text>concatenate(categoryRejections, promotionRejections)</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:literalExpression id="_EXPR_FINAL">
          <dmn:text>{AllowedPromotions: allowedResult, RejectedPromotions: rejectedResult}</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
    </dmn:context>
  </dmn:decision>
