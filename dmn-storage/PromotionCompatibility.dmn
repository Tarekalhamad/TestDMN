    </dmn:decisionTable>
  </dmn:decision>
  <dmn:decision id="_DECISION_PROMO_RULES" name="PromotionRules">
    <dmn:extensionElements />
    <dmn:variable id="_VAR_PROMO_RULES" name="PromotionRules" typeRef="tPromotionRuleList" />
    <dmn:decisionTable id="_DT_PROMO_RULES" hitPolicy="COLLECT" preferredOrientation="Rule-as-Row" outputLabel="PromotionRules">
