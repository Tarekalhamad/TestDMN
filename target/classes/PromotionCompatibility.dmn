<?xml version="1.0" encoding="UTF-8"?>
<dmn:definitions xmlns:dmn="http://www.omg.org/spec/DMN/20180521/MODEL/"
                 xmlns="https://telenor.se/promotion-compatibility"
                 xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
                 xmlns:kie="http://www.drools.org/kie/dmn/1.2"
                 xmlns:feel="http://www.omg.org/spec/DMN/20180521/FEEL/"
                 xmlns:dmndi="http://www.omg.org/spec/DMN/20180521/DMNDI/"
                 xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
                 id="_PROMO_COMPAT_001"
                 name="PromotionCompatibility"
                 expressionLanguage="http://www.omg.org/spec/DMN/20180521/FEEL/"
                 typeLanguage="http://www.omg.org/spec/DMN/20180521/FEEL/"
                 namespace="https://telenor.se/promotion-compatibility">

  <!-- ============================================================ -->
  <!-- ITEM DEFINITIONS (Custom Data Types)                         -->
  <!-- ============================================================ -->

  <!-- Input promotion structure -->
  <dmn:itemDefinition id="_tPromotion" name="tPromotion" isCollection="false">
    <dmn:itemComponent id="_tPromotion_id" name="promotionId" isCollection="false">
      <dmn:typeRef>string</dmn:typeRef>
    </dmn:itemComponent>
    <dmn:itemComponent id="_tPromotion_name" name="promotionName" isCollection="false">
      <dmn:typeRef>string</dmn:typeRef>
    </dmn:itemComponent>
    <dmn:itemComponent id="_tPromotion_baseType" name="promotionBaseType" isCollection="false">
      <dmn:typeRef>string</dmn:typeRef>
    </dmn:itemComponent>
    <dmn:itemComponent id="_tPromotion_category" name="discountCategory" isCollection="false">
      <dmn:typeRef>string</dmn:typeRef>
    </dmn:itemComponent>
  </dmn:itemDefinition>

  <!-- Collection of input promotions -->
  <dmn:itemDefinition id="_tPromotionList" name="tPromotionList" isCollection="true">
    <dmn:typeRef>tPromotion</dmn:typeRef>
  </dmn:itemDefinition>

  <!-- Output allowed promotion structure -->
  <dmn:itemDefinition id="_tAllowedPromotion" name="tAllowedPromotion" isCollection="false">
    <dmn:itemComponent id="_tAllowed_id" name="promotionId" isCollection="false">
      <dmn:typeRef>string</dmn:typeRef>
    </dmn:itemComponent>
    <dmn:itemComponent id="_tAllowed_name" name="promotionName" isCollection="false">
      <dmn:typeRef>string</dmn:typeRef>
    </dmn:itemComponent>
    <dmn:itemComponent id="_tAllowed_category" name="discountCategory" isCollection="false">
      <dmn:typeRef>string</dmn:typeRef>
    </dmn:itemComponent>
    <dmn:itemComponent id="_tAllowed_order" name="appliedOrder" isCollection="false">
      <dmn:typeRef>number</dmn:typeRef>
    </dmn:itemComponent>
  </dmn:itemDefinition>

  <!-- Collection of allowed promotions -->
  <dmn:itemDefinition id="_tAllowedPromotionList" name="tAllowedPromotionList" isCollection="true">
    <dmn:typeRef>tAllowedPromotion</dmn:typeRef>
  </dmn:itemDefinition>

  <!-- Output rejected promotion structure -->
  <dmn:itemDefinition id="_tRejectedPromotion" name="tRejectedPromotion" isCollection="false">
    <dmn:itemComponent id="_tRejected_id" name="promotionId" isCollection="false">
      <dmn:typeRef>string</dmn:typeRef>
    </dmn:itemComponent>
    <dmn:itemComponent id="_tRejected_name" name="promotionName" isCollection="false">
      <dmn:typeRef>string</dmn:typeRef>
    </dmn:itemComponent>
    <dmn:itemComponent id="_tRejected_category" name="discountCategory" isCollection="false">
      <dmn:typeRef>string</dmn:typeRef>
    </dmn:itemComponent>
    <dmn:itemComponent id="_tRejected_reason" name="reason" isCollection="false">
      <dmn:typeRef>string</dmn:typeRef>
    </dmn:itemComponent>
  </dmn:itemDefinition>

  <!-- Collection of rejected promotions -->
  <dmn:itemDefinition id="_tRejectedPromotionList" name="tRejectedPromotionList" isCollection="true">
    <dmn:typeRef>tRejectedPromotion</dmn:typeRef>
  </dmn:itemDefinition>

  <!-- Precedence row type -->
  <dmn:itemDefinition id="_tPrecedenceRow" name="tPrecedenceRow" isCollection="false">
    <dmn:itemComponent id="_tPrecRow_cat" name="discountCategory" isCollection="false">
      <dmn:typeRef>string</dmn:typeRef>
    </dmn:itemComponent>
    <dmn:itemComponent id="_tPrecRow_rank" name="precedenceRank" isCollection="false">
      <dmn:typeRef>number</dmn:typeRef>
    </dmn:itemComponent>
  </dmn:itemDefinition>

  <dmn:itemDefinition id="_tPrecedenceList" name="tPrecedenceList" isCollection="true">
    <dmn:typeRef>tPrecedenceRow</dmn:typeRef>
  </dmn:itemDefinition>

  <!-- Category incompatibility row type -->
  <dmn:itemDefinition id="_tCatIncompatRow" name="tCatIncompatRow" isCollection="false">
    <dmn:itemComponent id="_tCatInc_a" name="categoryA" isCollection="false">
      <dmn:typeRef>string</dmn:typeRef>
    </dmn:itemComponent>
    <dmn:itemComponent id="_tCatInc_b" name="categoryB" isCollection="false">
      <dmn:typeRef>string</dmn:typeRef>
    </dmn:itemComponent>
    <dmn:itemComponent id="_tCatInc_winner" name="overrideWinner" isCollection="false">
      <dmn:typeRef>string</dmn:typeRef>
    </dmn:itemComponent>
  </dmn:itemDefinition>

  <dmn:itemDefinition id="_tCatIncompatList" name="tCatIncompatList" isCollection="true">
    <dmn:typeRef>tCatIncompatRow</dmn:typeRef>
  </dmn:itemDefinition>

  <!-- Individual incompatibility row type -->
  <dmn:itemDefinition id="_tIndivIncompatRow" name="tIndivIncompatRow" isCollection="false">
    <dmn:itemComponent id="_tIndInc_blocked" name="blockedPromotionId" isCollection="false">
      <dmn:typeRef>string</dmn:typeRef>
    </dmn:itemComponent>
    <dmn:itemComponent id="_tIndInc_cat" name="whenCategoryPresent" isCollection="false">
      <dmn:typeRef>string</dmn:typeRef>
    </dmn:itemComponent>
    <dmn:itemComponent id="_tIndInc_promo" name="whenPromotionIdPresent" isCollection="false">
      <dmn:typeRef>string</dmn:typeRef>
    </dmn:itemComponent>
    <dmn:itemComponent id="_tIndInc_rule" name="ruleName" isCollection="false">
      <dmn:typeRef>string</dmn:typeRef>
    </dmn:itemComponent>
  </dmn:itemDefinition>

  <dmn:itemDefinition id="_tIndivIncompatList" name="tIndivIncompatList" isCollection="true">
    <dmn:typeRef>tIndivIncompatRow</dmn:typeRef>
  </dmn:itemDefinition>

  <!-- ============================================================ -->
  <!-- INPUT DATA                                                   -->
  <!-- ============================================================ -->

  <dmn:inputData id="_INPUT_ELIGIBLE" name="EligiblePromotions">
    <dmn:variable id="_VAR_ELIGIBLE" name="EligiblePromotions" typeRef="tPromotionList"/>
  </dmn:inputData>

  <!-- ============================================================ -->
  <!-- DECISION TABLE 1: Category Precedence                        -->
  <!-- Lower precedenceRank = higher priority = wins conflicts.     -->
  <!-- Business managers: add/remove/reorder rows as needed.        -->
  <!-- ============================================================ -->

  <dmn:decision id="_DECISION_PRECEDENCE" name="CategoryPrecedence">
    <dmn:variable id="_VAR_PRECEDENCE" name="CategoryPrecedence" typeRef="tPrecedenceList"/>
    <dmn:decisionTable id="_DT_PRECEDENCE" hitPolicy="COLLECT" outputLabel="CategoryPrecedence">
      <dmn:input id="_DT_PREC_IN1">
        <dmn:inputExpression id="_DT_PREC_IE1" typeRef="string">
          <dmn:text>"match"</dmn:text>
        </dmn:inputExpression>
      </dmn:input>
      <dmn:output id="_DT_PREC_OUT1" name="discountCategory" typeRef="string"/>
      <dmn:output id="_DT_PREC_OUT2" name="precedenceRank" typeRef="number"/>
      <dmn:rule id="_DT_PREC_R1">
        <dmn:inputEntry id="_DT_PREC_R1_I1"><dmn:text>-</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="_DT_PREC_R1_O1"><dmn:text>"EmployeeDiscount"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_PREC_R1_O2"><dmn:text>1</dmn:text></dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="_DT_PREC_R2">
        <dmn:inputEntry id="_DT_PREC_R2_I1"><dmn:text>-</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="_DT_PREC_R2_O1"><dmn:text>"ComplaintDiscount"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_PREC_R2_O2"><dmn:text>2</dmn:text></dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="_DT_PREC_R3">
        <dmn:inputEntry id="_DT_PREC_R3_I1"><dmn:text>-</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="_DT_PREC_R3_O1"><dmn:text>"SaveDeskDiscount"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_PREC_R3_O2"><dmn:text>3</dmn:text></dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="_DT_PREC_R4">
        <dmn:inputEntry id="_DT_PREC_R4_I1"><dmn:text>-</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="_DT_PREC_R4_O1"><dmn:text>"ChurnBlockerDiscount"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_PREC_R4_O2"><dmn:text>4</dmn:text></dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="_DT_PREC_R5">
        <dmn:inputEntry id="_DT_PREC_R5_I1"><dmn:text>-</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="_DT_PREC_R5_O1"><dmn:text>"SignUpDiscount"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_PREC_R5_O2"><dmn:text>5</dmn:text></dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="_DT_PREC_R6">
        <dmn:inputEntry id="_DT_PREC_R6_I1"><dmn:text>-</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="_DT_PREC_R6_O1"><dmn:text>"SignUpDiscountLimited"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_PREC_R6_O2"><dmn:text>6</dmn:text></dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="_DT_PREC_R7">
        <dmn:inputEntry id="_DT_PREC_R7_I1"><dmn:text>-</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="_DT_PREC_R7_O1"><dmn:text>"LegacyBindingDiscount"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_PREC_R7_O2"><dmn:text>7</dmn:text></dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="_DT_PREC_R8">
        <dmn:inputEntry id="_DT_PREC_R8_I1"><dmn:text>-</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="_DT_PREC_R8_O1"><dmn:text>"OTSDiscount"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_PREC_R8_O2"><dmn:text>8</dmn:text></dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="_DT_PREC_R9">
        <dmn:inputEntry id="_DT_PREC_R9_I1"><dmn:text>-</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="_DT_PREC_R9_O1"><dmn:text>"HWSubscriptionDiscount"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_PREC_R9_O2"><dmn:text>9</dmn:text></dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="_DT_PREC_R10">
        <dmn:inputEntry id="_DT_PREC_R10_I1"><dmn:text>-</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="_DT_PREC_R10_O1"><dmn:text>"HWSubscriptionDiscountLimited"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_PREC_R10_O2"><dmn:text>10</dmn:text></dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="_DT_PREC_R11">
        <dmn:inputEntry id="_DT_PREC_R11_I1"><dmn:text>-</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="_DT_PREC_R11_O1"><dmn:text>"HWSubscriptionDiscountAccessory"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_PREC_R11_O2"><dmn:text>11</dmn:text></dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="_DT_PREC_R12">
        <dmn:inputEntry id="_DT_PREC_R12_I1"><dmn:text>-</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="_DT_PREC_R12_O1"><dmn:text>"HWDiscount"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_PREC_R12_O2"><dmn:text>12</dmn:text></dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="_DT_PREC_R13">
        <dmn:inputEntry id="_DT_PREC_R13_I1"><dmn:text>-</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="_DT_PREC_R13_O1"><dmn:text>"GeoDiscount"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_PREC_R13_O2"><dmn:text>13</dmn:text></dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="_DT_PREC_R14">
        <dmn:inputEntry id="_DT_PREC_R14_I1"><dmn:text>-</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="_DT_PREC_R14_O1"><dmn:text>"KomboDiscount"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_PREC_R14_O2"><dmn:text>14</dmn:text></dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="_DT_PREC_R15">
        <dmn:inputEntry id="_DT_PREC_R15_I1"><dmn:text>-</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="_DT_PREC_R15_O1"><dmn:text>"PromotionOffering"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_PREC_R15_O2"><dmn:text>15</dmn:text></dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="_DT_PREC_R16">
        <dmn:inputEntry id="_DT_PREC_R16_I1"><dmn:text>-</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="_DT_PREC_R16_O1"><dmn:text>"RecurringExtraSurf"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_PREC_R16_O2"><dmn:text>16</dmn:text></dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="_DT_PREC_R17">
        <dmn:inputEntry id="_DT_PREC_R17_I1"><dmn:text>-</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="_DT_PREC_R17_O1"><dmn:text>"MiscMigratedDiscount"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_PREC_R17_O2"><dmn:text>17</dmn:text></dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="_DT_PREC_R18">
        <dmn:inputEntry id="_DT_PREC_R18_I1"><dmn:text>-</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="_DT_PREC_R18_O1"><dmn:text>"MiscMigratedDiscountLimited"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_PREC_R18_O2"><dmn:text>18</dmn:text></dmn:outputEntry>
      </dmn:rule>
    </dmn:decisionTable>
  </dmn:decision>

  <!-- ============================================================ -->
  <!-- DECISION TABLE 2: Category Incompatibilities                  -->
  <!-- Declares which discount category pairs CANNOT coexist.        -->
  <!-- overrideWinner: leave empty to use precedence, or set a       -->
  <!-- category name to force that category as the winner.           -->
  <!-- Business managers: add/remove rows to change rules.           -->
  <!-- ============================================================ -->

  <dmn:decision id="_DECISION_CAT_INCOMPAT" name="CategoryIncompatibilities">
    <dmn:variable id="_VAR_CAT_INCOMPAT" name="CategoryIncompatibilities" typeRef="tCatIncompatList"/>
    <dmn:decisionTable id="_DT_CAT_INCOMPAT" hitPolicy="COLLECT" outputLabel="CategoryIncompatibilities">
      <dmn:input id="_DT_CI_IN1">
        <dmn:inputExpression id="_DT_CI_IE1" typeRef="string">
          <dmn:text>"match"</dmn:text>
        </dmn:inputExpression>
      </dmn:input>
      <dmn:output id="_DT_CI_OUT1" name="categoryA" typeRef="string"/>
      <dmn:output id="_DT_CI_OUT2" name="categoryB" typeRef="string"/>
      <dmn:output id="_DT_CI_OUT3" name="overrideWinner" typeRef="string"/>
      <dmn:rule id="_DT_CI_R1">
        <dmn:inputEntry id="_DT_CI_R1_I1"><dmn:text>-</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="_DT_CI_R1_O1"><dmn:text>"EmployeeDiscount"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_CI_R1_O2"><dmn:text>"LegacyBindingDiscount"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_CI_R1_O3"><dmn:text></dmn:text></dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="_DT_CI_R2">
        <dmn:inputEntry id="_DT_CI_R2_I1"><dmn:text>-</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="_DT_CI_R2_O1"><dmn:text>"EmployeeDiscount"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_CI_R2_O2"><dmn:text>"OTSDiscount"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_CI_R2_O3"><dmn:text></dmn:text></dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="_DT_CI_R3">
        <dmn:inputEntry id="_DT_CI_R3_I1"><dmn:text>-</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="_DT_CI_R3_O1"><dmn:text>"EmployeeDiscount"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_CI_R3_O2"><dmn:text>"HWSubscriptionDiscount"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_CI_R3_O3"><dmn:text></dmn:text></dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="_DT_CI_R4">
        <dmn:inputEntry id="_DT_CI_R4_I1"><dmn:text>-</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="_DT_CI_R4_O1"><dmn:text>"EmployeeDiscount"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_CI_R4_O2"><dmn:text>"ChurnBlockerDiscount"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_CI_R4_O3"><dmn:text></dmn:text></dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="_DT_CI_R5">
        <dmn:inputEntry id="_DT_CI_R5_I1"><dmn:text>-</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="_DT_CI_R5_O1"><dmn:text>"LegacyBindingDiscount"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_CI_R5_O2"><dmn:text>"HWSubscriptionDiscount"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_CI_R5_O3"><dmn:text></dmn:text></dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="_DT_CI_R6">
        <dmn:inputEntry id="_DT_CI_R6_I1"><dmn:text>-</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="_DT_CI_R6_O1"><dmn:text>"LegacyBindingDiscount"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_CI_R6_O2"><dmn:text>"HWSubscriptionDiscountLimited"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_CI_R6_O3"><dmn:text></dmn:text></dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="_DT_CI_R7">
        <dmn:inputEntry id="_DT_CI_R7_I1"><dmn:text>-</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="_DT_CI_R7_O1"><dmn:text>"LegacyBindingDiscount"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_CI_R7_O2"><dmn:text>"HWSubscriptionDiscountAccessory"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_CI_R7_O3"><dmn:text></dmn:text></dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="_DT_CI_R8">
        <dmn:inputEntry id="_DT_CI_R8_I1"><dmn:text>-</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="_DT_CI_R8_O1"><dmn:text>"OTSDiscount"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_CI_R8_O2"><dmn:text>"SignUpDiscount"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_CI_R8_O3"><dmn:text></dmn:text></dmn:outputEntry>
      </dmn:rule>
      <dmn:rule id="_DT_CI_R9">
        <dmn:inputEntry id="_DT_CI_R9_I1"><dmn:text>-</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="_DT_CI_R9_O1"><dmn:text>"OTSDiscount"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_CI_R9_O2"><dmn:text>"SignUpDiscountLimited"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_CI_R9_O3"><dmn:text></dmn:text></dmn:outputEntry>
      </dmn:rule>
    </dmn:decisionTable>
  </dmn:decision>

  <!-- ============================================================ -->
  <!-- DECISION TABLE 3: Individual Incompatibilities                -->
  <!-- Blocks specific promotion IDs when a category or promotion   -->
  <!-- is present. Business managers: add rows as needed.            -->
  <!-- ============================================================ -->

  <dmn:decision id="_DECISION_INDIV_INCOMPAT" name="IndividualIncompatibilities">
    <dmn:variable id="_VAR_INDIV_INCOMPAT" name="IndividualIncompatibilities" typeRef="tIndivIncompatList"/>
    <dmn:decisionTable id="_DT_INDIV_INCOMPAT" hitPolicy="COLLECT" outputLabel="IndividualIncompatibilities">
      <dmn:input id="_DT_II_IN1">
        <dmn:inputExpression id="_DT_II_IE1" typeRef="string">
          <dmn:text>"match"</dmn:text>
        </dmn:inputExpression>
      </dmn:input>
      <dmn:output id="_DT_II_OUT1" name="blockedPromotionId" typeRef="string"/>
      <dmn:output id="_DT_II_OUT2" name="whenCategoryPresent" typeRef="string"/>
      <dmn:output id="_DT_II_OUT3" name="whenPromotionIdPresent" typeRef="string"/>
      <dmn:output id="_DT_II_OUT4" name="ruleName" typeRef="string"/>
      <dmn:rule id="_DT_II_R1">
        <dmn:inputEntry id="_DT_II_R1_I1"><dmn:text>-</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="_DT_II_R1_O1"><dmn:text>"PROMO-ATL-001"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_II_R1_O2"><dmn:text>"EmployeeDiscount"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_II_R1_O3"><dmn:text></dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_II_R1_O4"><dmn:text>"Block ATL campaign when employee discount present"</dmn:text></dmn:outputEntry>
      </dmn:rule>
      <!-- Rule 2: Block by specific promotion ID presence (no category trigger) -->
      <dmn:rule id="_DT_II_R2">
        <dmn:inputEntry id="_DT_II_R2_I1"><dmn:text>-</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="_DT_II_R2_O1"><dmn:text>"PROMO-SUMMER-01"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_II_R2_O2"><dmn:text></dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_II_R2_O3"><dmn:text>"PROMO-VIP-99"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_II_R2_O4"><dmn:text>"Block summer promo when VIP promo present"</dmn:text></dmn:outputEntry>
      </dmn:rule>
      <!-- Rule 3: Block by EITHER category OR promotion ID (OR logic) -->
      <dmn:rule id="_DT_II_R3">
        <dmn:inputEntry id="_DT_II_R3_I1"><dmn:text>-</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="_DT_II_R3_O1"><dmn:text>"PROMO-FLASH-01"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_II_R3_O2"><dmn:text>"OTSDiscount"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_II_R3_O3"><dmn:text>"PROMO-LOYAL-01"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_II_R3_O4"><dmn:text>"Block flash sale when OTS discount or loyalty promo present"</dmn:text></dmn:outputEntry>
      </dmn:rule>
      <!-- Rule 4: Block by category - SaveDeskDiscount blocks a specific retention offer -->
      <dmn:rule id="_DT_II_R4">
        <dmn:inputEntry id="_DT_II_R4_I1"><dmn:text>-</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="_DT_II_R4_O1"><dmn:text>"PROMO-RETAIN-05"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_II_R4_O2"><dmn:text>"SaveDeskDiscount"</dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_II_R4_O3"><dmn:text></dmn:text></dmn:outputEntry>
        <dmn:outputEntry id="_DT_II_R4_O4"><dmn:text>"Block retention offer when save desk discount present"</dmn:text></dmn:outputEntry>
      </dmn:rule>
    </dmn:decisionTable>
  </dmn:decision>

  <!-- ============================================================ -->
  <!-- MAIN DECISION: CompatibilityResult                            -->
  <!-- Uses the three lookup tables above + FEEL logic to resolve    -->
  <!-- conflicts and produce AllowedPromotions + RejectedPromotions. -->
  <!-- Business managers should NOT need to modify this decision.    -->
  <!-- ============================================================ -->

  <dmn:decision id="_DECISION_RESULT" name="CompatibilityResult">
    <dmn:variable id="_VAR_RESULT" name="CompatibilityResult" typeRef="Any"/>
    <dmn:informationRequirement id="_IR_ELIGIBLE">
      <dmn:requiredInput href="#_INPUT_ELIGIBLE"/>
    </dmn:informationRequirement>
    <dmn:informationRequirement id="_IR_PRECEDENCE">
      <dmn:requiredDecision href="#_DECISION_PRECEDENCE"/>
    </dmn:informationRequirement>
    <dmn:informationRequirement id="_IR_CAT_INCOMPAT">
      <dmn:requiredDecision href="#_DECISION_CAT_INCOMPAT"/>
    </dmn:informationRequirement>
    <dmn:informationRequirement id="_IR_INDIV_INCOMPAT">
      <dmn:requiredDecision href="#_DECISION_INDIV_INCOMPAT"/>
    </dmn:informationRequirement>

    <dmn:context id="_CTX_RESULT">

      <!-- Aliases: map sub-decision names to camelCase used by FEEL logic below -->
      <dmn:contextEntry>
        <dmn:variable id="_CE_PREC" name="categoryPrecedence" typeRef="Any"/>
        <dmn:literalExpression id="_EXPR_PREC">
          <dmn:text>CategoryPrecedence</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_INCOMPAT" name="categoryIncompatibilities" typeRef="Any"/>
        <dmn:literalExpression id="_EXPR_INCOMPAT">
          <dmn:text>CategoryIncompatibilities</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>
      <dmn:contextEntry>
        <dmn:variable id="_CE_INDIV" name="individualIncompatibilities" typeRef="Any"/>
        <dmn:literalExpression id="_EXPR_INDIV">
          <dmn:text>IndividualIncompatibilities</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>

      <!-- Helper: look up precedence rank for a category -->
      <dmn:contextEntry>
        <dmn:variable id="_CE_PREC_OF" name="precedenceOf" typeRef="Any"/>
        <dmn:literalExpression id="_EXPR_PREC_OF">
          <dmn:text><![CDATA[function(cat) if count(categoryPrecedence[discountCategory = cat]) > 0 then (categoryPrecedence[discountCategory = cat]).precedenceRank[1] else 999]]></dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>

      <!-- Step 1: Distinct categories in the input -->
      <dmn:contextEntry>
        <dmn:variable id="_CE_CATS" name="categoriesPresent" typeRef="Any"/>
        <dmn:literalExpression id="_EXPR_CATS">
          <dmn:text>distinct values(for p in EligiblePromotions return p.discountCategory)</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>

      <!-- Step 2: Active conflicts (both categories present) -->
      <dmn:contextEntry>
        <dmn:variable id="_CE_CONFLICTS" name="activeConflicts" typeRef="Any"/>
        <dmn:literalExpression id="_EXPR_CONFLICTS">
          <dmn:text>categoryIncompatibilities[list contains(categoriesPresent, categoryA) and list contains(categoriesPresent, categoryB)]</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>

      <!-- Step 3: Resolve each conflict to winner/loser -->
      <dmn:contextEntry>
        <dmn:variable id="_CE_RESOLUTIONS" name="conflictResolutions" typeRef="Any"/>
        <dmn:literalExpression id="_EXPR_RESOLUTIONS">
          <dmn:text><![CDATA[for c in activeConflicts return {winnerCategory: if c.overrideWinner != null then c.overrideWinner else if precedenceOf(c.categoryA) < precedenceOf(c.categoryB) then c.categoryA else c.categoryB, loserCategory: if c.overrideWinner != null then (if c.overrideWinner = c.categoryA then c.categoryB else c.categoryA) else if precedenceOf(c.categoryA) < precedenceOf(c.categoryB) then c.categoryB else c.categoryA}]]></dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>

      <!-- Step 4: Collect losing categories -->
      <dmn:contextEntry>
        <dmn:variable id="_CE_LOSERS" name="losingCategories" typeRef="Any"/>
        <dmn:literalExpression id="_EXPR_LOSERS">
          <dmn:text>distinct values(for cr in conflictResolutions return cr.loserCategory)</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>

      <!-- Step 5: Find active individual blocks -->
      <dmn:contextEntry>
        <dmn:variable id="_CE_ACTIVE_BLOCKS" name="activeBlocks" typeRef="Any"/>
        <dmn:literalExpression id="_EXPR_ACTIVE_BLOCKS">
          <dmn:text>(for rule in individualIncompatibilities return if (rule.whenCategoryPresent != null and list contains(categoriesPresent, rule.whenCategoryPresent)) or (rule.whenPromotionIdPresent != null and (some p in EligiblePromotions satisfies p.promotionId = rule.whenPromotionIdPresent)) then rule else null)[item != null]</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>

      <!-- Step 6: Extract blocked promotion IDs -->
      <dmn:contextEntry>
        <dmn:variable id="_CE_BLOCKED_IDS" name="blockedPromotionIds" typeRef="Any"/>
        <dmn:literalExpression id="_EXPR_BLOCKED_IDS">
          <dmn:text>distinct values(for b in activeBlocks return b.blockedPromotionId)</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>

      <!-- Step 7: Filter out losers and blocked promotions -->
      <dmn:contextEntry>
        <dmn:variable id="_CE_SURVIVING" name="surviving" typeRef="Any"/>
        <dmn:literalExpression id="_EXPR_SURVIVING">
          <dmn:text>EligiblePromotions[not(list contains(losingCategories, discountCategory)) and not(list contains(blockedPromotionIds, promotionId))]</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>

      <!-- Step 8: Sort survivors by precedence rank -->
      <dmn:contextEntry>
        <dmn:variable id="_CE_SORTED" name="sorted" typeRef="Any"/>
        <dmn:literalExpression id="_EXPR_SORTED">
          <dmn:text><![CDATA[sort(surviving, function(a, b) precedenceOf(a.discountCategory) < precedenceOf(b.discountCategory))]]></dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>

      <!-- Step 9: Build AllowedPromotions list with appliedOrder -->
      <dmn:contextEntry>
        <dmn:variable id="_CE_ALLOWED" name="allowedResult" typeRef="Any"/>
        <dmn:literalExpression id="_EXPR_ALLOWED">
          <dmn:text>if count(sorted) = 0 then [] else for i in 1..count(sorted) return {promotionId: sorted[i].promotionId, promotionName: sorted[i].promotionName, discountCategory: sorted[i].discountCategory, appliedOrder: i}</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>

      <!-- Step 10: Build RejectedPromotions - category conflicts -->
      <dmn:contextEntry>
        <dmn:variable id="_CE_CAT_REJECTED" name="categoryRejections" typeRef="Any"/>
        <dmn:literalExpression id="_EXPR_CAT_REJECTED">
          <dmn:text>for p in EligiblePromotions[list contains(losingCategories, discountCategory)] return {promotionId: p.promotionId, promotionName: p.promotionName, discountCategory: p.discountCategory, reason: "Incompatible with " + conflictResolutions[loserCategory = p.discountCategory][1].winnerCategory + " (higher precedence)"}</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>

      <!-- Step 11: Build RejectedPromotions - individual blocks -->
      <dmn:contextEntry>
        <dmn:variable id="_CE_IND_REJECTED" name="individualRejections" typeRef="Any"/>
        <dmn:literalExpression id="_EXPR_IND_REJECTED">
          <dmn:text>for p in EligiblePromotions[list contains(blockedPromotionIds, promotionId) and not(list contains(losingCategories, discountCategory))] return {promotionId: p.promotionId, promotionName: p.promotionName, discountCategory: p.discountCategory, reason: "Individually blocked: " + activeBlocks[blockedPromotionId = p.promotionId][1].ruleName}</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>

      <!-- Step 12: Combine all rejections -->
      <dmn:contextEntry>
        <dmn:variable id="_CE_REJECTED" name="rejectedResult" typeRef="Any"/>
        <dmn:literalExpression id="_EXPR_REJECTED">
          <dmn:text>concatenate(categoryRejections, individualRejections)</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>

      <!-- Final result: context with both lists -->
      <dmn:contextEntry>
        <dmn:literalExpression id="_EXPR_FINAL">
          <dmn:text>{AllowedPromotions: allowedResult, RejectedPromotions: rejectedResult}</dmn:text>
        </dmn:literalExpression>
      </dmn:contextEntry>

    </dmn:context>
  </dmn:decision>

  <!-- ============================================================ -->
  <!-- DMNDI: Diagram Layout                                        -->
  <!-- ============================================================ -->

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="_DIAGRAM_001" name="Promotion Compatibility DRG">
      <di:extension>
        <kie:ComponentsWidthsExtension/>
      </di:extension>

      <!-- Input data at the bottom -->
      <dmndi:DMNShape id="dmnshape-_INPUT_ELIGIBLE" dmnElementRef="_INPUT_ELIGIBLE" isCollapsed="false">
        <dc:Bounds x="350" y="550" width="200" height="50"/>
        <dmndi:DMNLabel/>
      </dmndi:DMNShape>

      <!-- Sub-decision tables in the middle row -->
      <dmndi:DMNShape id="dmnshape-_DECISION_PRECEDENCE" dmnElementRef="_DECISION_PRECEDENCE" isCollapsed="false">
        <dc:Bounds x="50" y="350" width="250" height="50"/>
        <dmndi:DMNLabel/>
      </dmndi:DMNShape>

      <dmndi:DMNShape id="dmnshape-_DECISION_CAT_INCOMPAT" dmnElementRef="_DECISION_CAT_INCOMPAT" isCollapsed="false">
        <dc:Bounds x="350" y="350" width="250" height="50"/>
        <dmndi:DMNLabel/>
      </dmndi:DMNShape>

      <dmndi:DMNShape id="dmnshape-_DECISION_INDIV_INCOMPAT" dmnElementRef="_DECISION_INDIV_INCOMPAT" isCollapsed="false">
        <dc:Bounds x="650" y="350" width="250" height="50"/>
        <dmndi:DMNLabel/>
      </dmndi:DMNShape>

      <!-- Main decision at the top -->
      <dmndi:DMNShape id="dmnshape-_DECISION_RESULT" dmnElementRef="_DECISION_RESULT" isCollapsed="false">
        <dc:Bounds x="300" y="150" width="300" height="50"/>
        <dmndi:DMNLabel/>
      </dmndi:DMNShape>

      <!-- Edge: Input -> Main decision -->
      <dmndi:DMNEdge id="dmnedge-_IR_ELIGIBLE" dmnElementRef="_IR_ELIGIBLE">
        <di:waypoint x="450" y="550"/>
        <di:waypoint x="450" y="200"/>
      </dmndi:DMNEdge>

      <!-- Edge: CategoryPrecedence -> Main decision -->
      <dmndi:DMNEdge id="dmnedge-_IR_PRECEDENCE" dmnElementRef="_IR_PRECEDENCE">
        <di:waypoint x="175" y="350"/>
        <di:waypoint x="375" y="200"/>
      </dmndi:DMNEdge>

      <!-- Edge: CategoryIncompatibilities -> Main decision -->
      <dmndi:DMNEdge id="dmnedge-_IR_CAT_INCOMPAT" dmnElementRef="_IR_CAT_INCOMPAT">
        <di:waypoint x="475" y="350"/>
        <di:waypoint x="450" y="200"/>
      </dmndi:DMNEdge>

      <!-- Edge: IndividualIncompatibilities -> Main decision -->
      <dmndi:DMNEdge id="dmnedge-_IR_INDIV_INCOMPAT" dmnElementRef="_IR_INDIV_INCOMPAT">
        <di:waypoint x="775" y="350"/>
        <di:waypoint x="525" y="200"/>
      </dmndi:DMNEdge>

    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</dmn:definitions>
